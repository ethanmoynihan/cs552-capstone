# Flip to false after `task backend:install:model` and the GGUF is downloaded.
USE_STUB_LLAMA=true

# llama.cpp (GGUF) — local dev path on Apple Silicon.
# Override if you place the model elsewhere.
# LLAMA_GGUF_PATH=./models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
# LLAMA_N_CTX=4096
# LLAMA_N_GPU_LAYERS=-1
# LLAMA_MAX_NEW_TOKENS=256
# LLAMA_TEMPERATURE=0.1

# Transformers / Phase 5 deploy path.
LLAMA_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
WHISPER_MODEL=small

CORS_ORIGINS=["http://localhost:5173"]
